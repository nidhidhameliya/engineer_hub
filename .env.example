# Engineering Intelligence Hub - Environment Variables
# Copy this file to .env and fill in your values

# =============================================================
# REQUIRED
# =============================================================
OPENAI_API_KEY=sk-your-openai-api-key-here

# =============================================================
# OPTIONAL
# =============================================================
# GitHub Personal Access Token (for private repo indexing)
GITHUB_TOKEN=ghp_your-github-token-here

# ChromaDB connection (used inside Docker)
CHROMA_HOST=chromadb
CHROMA_PORT=8000

# Upload directory
UPLOAD_DIR=./uploads

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Frontend API URL (change for production)
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_NAME=Engineer Hub
